{
    "name": "arui-presets-lint-monorepo",
    "private": true,
    "description": "Монорепозиторий с инструментами для разработки и валидации TypeScript/JavaScript проектов",
    "author": "core-ds contributors",
    "license": "MIT",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/core-ds/arui-presets-lint.git"
    },
    "workspaces": [
        "packages/*"
    ],
    "devDependencies": {
        "@changesets/changelog-github": "0.7.0",
        "@changesets/cli": "2.31.0",
        "arui-presets-lint": "workspace:*",
        "eslint-config-turbo": "2.9.18",
        "turbo": "2.9.18"
    },
    "scripts": {
        "build": "turbo run build",
        "test": "turbo run test",
        "test:unit": "turbo run test:unit",
        "lint": "turbo run lint",
        "lint:fix": "turbo run lint:fix",
        "format": "turbo run format",
        "format:check": "turbo run format:check",
        "release": "turbo run build && changeset publish",
        "release:snapshot": "turbo run build && changeset publish --tag snapshot --no-git-tag",
        "version-package": "changeset version",
        "version-package:snapshot": "changeset version --snapshot snapshot"
    },
    "packageManager": "yarn@4.16.0",
    "commitlint": {
        "extends": "./packages/arui-presets-lint/commitlint/index.ts"
    },
    "stylelint": {
        "extends": "./packages/arui-presets-lint/stylelint/index.ts"
    },
    "prettier": "./packages/arui-presets-lint/prettier/index.ts"
}
