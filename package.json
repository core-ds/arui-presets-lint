{
    "name": "arui-presets-lint",
    "version": "9.3.0-snapshot-7d455a7f98260a8a4b8e2420bc957c92de012fd9",
    "description": "Config files for arui-apps",
    "author": "core-ds contributors",
    "license": "MIT",
    "type": "module",
    "bin": "cli/index.mjs",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/core-ds/arui-presets-lint.git"
    },
    "dependencies": {
        "@alfalab/stylelint-core-vars": "2.0.0",
        "@commitlint/cli": "20.5.0",
        "@commitlint/config-conventional": "20.5.0",
        "@eslint/js": "9.39.4",
        "@types/eslint-plugin-jsx-a11y": "6.10.1",
        "@typescript-eslint/utils": "8.58.1",
        "eslint": "9.39.4",
        "eslint-config-flat-gitignore": "2.3.0",
        "eslint-import-resolver-typescript": "4.4.4",
        "eslint-plugin-check-file": "3.3.1",
        "eslint-plugin-de-morgan": "1.3.1",
        "eslint-plugin-import-x": "4.16.2",
        "eslint-plugin-jsx-a11y": "6.10.2",
        "eslint-plugin-n": "17.24.0",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "7.0.1",
        "eslint-plugin-simple-import-sort": "13.0.0",
        "eslint-plugin-unicorn": "64.0.0",
        "execa": "^9.6.1",
        "globals": "^17.0.0",
        "jiti": "^2.6.1",
        "lefthook": "2.1.5",
        "prettier": "3.8.1",
        "stylelint": "16.26.1",
        "typescript-eslint": "8.58.1"
    },
    "engines": {
        "node": ">=18.18.0"
    },
    "devDependencies": {
        "@alfalab/core-components": "50.9.0",
        "@changesets/changelog-github": "0.6.0",
        "@changesets/cli": "2.30.0",
        "@types/node": "24.12.2",
        "@types/react": "19.2.14",
        "es-toolkit": "1.45.1",
        "eslint-config-prettier": "10.1.8",
        "react": "19.2.5",
        "shx": "0.4.0",
        "tsx": "4.21.0",
        "typescript": "6.0.2"
    },
    "scripts": {
        "build": "shx rm -rf ./dist && tsc -p tsconfig.build.json && shx cp *.md dist/ && shx cp -r lefthook dist/lefthook",
        "test": "yarn build && eslint-config-prettier ./eslint/index.ts && tsx ./cli/duplicates-checker.ts && yarn lint",
        "lint": "yarn lint:styles && yarn lint:scripts && yarn format:check",
        "lint:fix": "yarn lint:styles --fix && yarn lint:scripts --fix && yarn format",
        "lint:styles": "tsx ./cli/index.mts styles",
        "lint:scripts": "tsx ./cli/index.mts scripts",
        "format": "tsx ./cli/index.mts format",
        "format:check": "tsx ./cli/index.mts format:check",
        "release": "changeset publish ./",
        "release:snapshot": "changeset publish --tag snapshot --no-git-tag",
        "version-package": "changeset version",
        "version-package:snapshot": "changeset version --snapshot snapshot"
    },
    "prettier": "./prettier",
    "stylelint": {
        "extends": "./stylelint"
    },
    "exports": {
        "./eslint": {
            "types": "./eslint/index.d.ts",
            "import": "./eslint/index.js"
        },
        "./eslint/config": {
            "types": "./eslint/config.d.ts",
            "import": "./eslint/config.js"
        },
        "./eslint/rules": {
            "types": "./eslint/rules/index.d.ts",
            "import": "./eslint/rules/index.js"
        },
        "./prettier": "./prettier/index.js",
        "./commitlint": "./commitlint/index.js",
        "./stylelint": "./stylelint/index.js"
    },
    "commitlint": {
        "extends": "./commitlint"
    },
    "packageManager": "yarn@4.13.0",
    "publishConfig": {
        "directory": "dist",
        "access": "public"
    }
}
