{
    "compilerOptions": {
        "target": "es2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "jsx": "react-jsx",
        "allowJs": true,
        "types": ["node"],
        "skipLibCheck": true,
        "declaration": true,
        "verbatimModuleSyntax": true,
        "resolveJsonModule": true
    }
}
